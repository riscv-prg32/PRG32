{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "PRG32: set target esp32c6",
      "type": "shell",
      "command": "idf.py",
      "args": [
        "-B",
        "build-esp32c6",
        "-D",
        "SDKCONFIG=build-esp32c6/sdkconfig",
        "-D",
        "SDKCONFIG_DEFAULTS=sdkconfig.defaults",
        "set-target",
        "esp32c6"
      ],
      "problemMatcher": []
    },
    {
      "label": "PRG32: menuconfig",
      "type": "shell",
      "command": "idf.py",
      "args": [
        "-B",
        "build-esp32c6",
        "-D",
        "SDKCONFIG=build-esp32c6/sdkconfig",
        "-D",
        "SDKCONFIG_DEFAULTS=sdkconfig.defaults",
        "-D",
        "IDF_TARGET=esp32c6",
        "menuconfig"
      ],
      "problemMatcher": []
    },
    {
      "label": "PRG32: build",
      "type": "shell",
      "command": "idf.py",
      "args": [
        "-B",
        "build-esp32c6",
        "-D",
        "SDKCONFIG=build-esp32c6/sdkconfig",
        "-D",
        "SDKCONFIG_DEFAULTS=sdkconfig.defaults",
        "-D",
        "IDF_TARGET=esp32c6",
        "build"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "PRG32: flash monitor",
      "type": "shell",
      "command": "idf.py",
      "args": [
        "-B",
        "build-esp32c6",
        "-D",
        "SDKCONFIG=build-esp32c6/sdkconfig",
        "-D",
        "SDKCONFIG_DEFAULTS=sdkconfig.defaults",
        "-D",
        "IDF_TARGET=esp32c6",
        "flash",
        "monitor"
      ],
      "problemMatcher": []
    },
    {
      "label": "PRG32: qemu set target esp32c3",
      "type": "shell",
      "command": "idf.py",
      "args": [
        "-B",
        "build-qemu",
        "-D",
        "SDKCONFIG=build-qemu/sdkconfig",
        "-D",
        "SDKCONFIG_DEFAULTS=sdkconfig.defaults.qemu",
        "set-target",
        "esp32c3"
      ],
      "problemMatcher": []
    },
    {
      "label": "PRG32: qemu build",
      "type": "shell",
      "command": "idf.py",
      "args": [
        "-B",
        "build-qemu",
        "-D",
        "SDKCONFIG=build-qemu/sdkconfig",
        "-D",
        "SDKCONFIG_DEFAULTS=sdkconfig.defaults.qemu",
        "-D",
        "IDF_TARGET=esp32c3",
        "build"
      ],
      "group": "build",
      "problemMatcher": []
    },
    {
      "label": "PRG32: qemu screen",
      "type": "shell",
      "command": "idf.py",
      "args": [
        "-B",
        "build-qemu",
        "-D",
        "SDKCONFIG=build-qemu/sdkconfig",
        "-D",
        "SDKCONFIG_DEFAULTS=sdkconfig.defaults.qemu",
        "-D",
        "IDF_TARGET=esp32c3",
        "qemu",
        "--graphics",
        "monitor"
      ],
      "problemMatcher": []
    },
    {
      "label": "PRG32: qemu debug server",
      "type": "shell",
      "command": "idf.py",
      "args": [
        "-B",
        "build-qemu",
        "-D",
        "SDKCONFIG=build-qemu/sdkconfig",
        "-D",
        "SDKCONFIG_DEFAULTS=sdkconfig.defaults.qemu",
        "-D",
        "IDF_TARGET=esp32c3",
        "qemu",
        "--graphics",
        "--gdb",
        "monitor"
      ],
      "problemMatcher": []
    },
    {
      "label": "PRG32: qemu gdb",
      "type": "shell",
      "command": "idf.py",
      "args": [
        "-B",
        "build-qemu",
        "-D",
        "SDKCONFIG=build-qemu/sdkconfig",
        "-D",
        "SDKCONFIG_DEFAULTS=sdkconfig.defaults.qemu",
        "-D",
        "IDF_TARGET=esp32c3",
        "gdb"
      ],
      "problemMatcher": []
    },
    {
      "label": "PRG32: clean",
      "type": "shell",
      "command": "idf.py",
      "args": [
        "-B",
        "build-esp32c6",
        "-D",
        "SDKCONFIG=build-esp32c6/sdkconfig",
        "-D",
        "SDKCONFIG_DEFAULTS=sdkconfig.defaults",
        "-D",
        "IDF_TARGET=esp32c6",
        "fullclean"
      ],
      "problemMatcher": []
    },
    {
      "label": "PRG32: cartridge build",
      "type": "shell",
      "command": "python3",
      "args": [
        "tools/prg32_game.py",
        "build",
        "${input:prg32GameSource}",
        "--firmware-elf",
        "${input:prg32FirmwareElf}",
        "--entry-prefix",
        "${input:prg32EntryPrefix}",
        "--name",
        "${input:prg32CartName}",
        "--out",
        "${input:prg32CartOut}"
      ],
      "problemMatcher": []
    },
    {
      "label": "PRG32: cartridge upload hardware",
      "type": "shell",
      "command": "python3",
      "args": [
        "tools/prg32_game.py",
        "upload",
        "${input:prg32CartOut}",
        "--url",
        "${input:prg32HardwareUrl}"
      ],
      "problemMatcher": []
    },
    {
      "label": "PRG32: cartridge upload qemu",
      "type": "shell",
      "command": "python3",
      "args": [
        "tools/prg32_game.py",
        "upload-qemu",
        "${input:prg32QemuCartOut}",
        "--flash",
        "build-qemu/flash_image.bin"
      ],
      "problemMatcher": []
    },
    {
      "label": "PRG32: cartridge runtime hardware",
      "type": "shell",
      "command": "python3",
      "args": [
        "tools/prg32_game.py",
        "runtime",
        "--url",
        "${input:prg32HardwareUrl}"
      ],
      "problemMatcher": []
    },
    {
      "label": "PRG32: score server",
      "type": "shell",
      "command": "python3",
      "args": ["tools/prg32_score_server/app.py"],
      "problemMatcher": []
    }
  ],
  "inputs": [
    {
      "id": "prg32GameSource",
      "type": "promptString",
      "description": "Assembly game source",
      "default": "examples/games/asteroids/graphics/game.S"
    },
    {
      "id": "prg32FirmwareElf",
      "type": "promptString",
      "description": "Resident firmware ELF",
      "default": "build-esp32c6/PRG32.elf"
    },
    {
      "id": "prg32EntryPrefix",
      "type": "promptString",
      "description": "Game entry prefix",
      "default": "asteroids_graphics"
    },
    {
      "id": "prg32CartName",
      "type": "promptString",
      "description": "Cartridge name",
      "default": "asteroids"
    },
    {
      "id": "prg32CartOut",
      "type": "promptString",
      "description": "Hardware cartridge output",
      "default": "build-esp32c6/asteroids.prg32"
    },
    {
      "id": "prg32QemuCartOut",
      "type": "promptString",
      "description": "QEMU cartridge output",
      "default": "build-qemu/asteroids.prg32"
    },
    {
      "id": "prg32HardwareUrl",
      "type": "promptString",
      "description": "PRG32 hardware URL",
      "default": "http://192.168.4.1"
    }
  ]
}
