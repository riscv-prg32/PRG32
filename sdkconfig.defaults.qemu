# Use with: idf.py -B build-qemu -D SDKCONFIG_DEFAULTS=sdkconfig.defaults.qemu set-target esp32c3
CONFIG_PARTITION_TABLE_CUSTOM=y
CONFIG_PARTITION_TABLE_CUSTOM_FILENAME="partitions_prg32.csv"
CONFIG_PRG32_DISPLAY_QEMU_RGB=y
CONFIG_PRG32_QEMU_FAIL_ON_REAL_HW=y
CONFIG_PRG32_QEMU_UART_INPUT=y
CONFIG_PRG32_CART_RAM_EXTENDED=y
CONFIG_ESPTOOLPY_FLASHSIZE_4MB=y
CONFIG_PRG32_AUDIO_ENABLED=y
CONFIG_PRG32_AUDIO_SAMPLE_RATE=22050
CONFIG_PRG32_AUDIO_MODE_MONO=y
CONFIG_PRG32_AUDIO_MAX_VOICES=6
CONFIG_PRG32_SPLASH_ENABLED=y
CONFIG_PRG32_SPLASH_DURATION_MS=900
CONFIG_PRG32_SPLASH_SOUND_ENABLED=y
CONFIG_ESP_SYSTEM_MEMPROT_FEATURE=n
CONFIG_ESP_SYSTEM_PMP_IDRAM_SPLIT=n
