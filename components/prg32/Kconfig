menu "PRG32 framework"

choice PRG32_DISPLAY_BACKEND
    prompt "Display backend"
    default PRG32_DISPLAY_ILI9341
    help
        Select the display implementation used by the PRG32 graphics ABI.
        The ILI9341 backend is for the physical ESP32-C6 classroom board. The
        QEMU RGB backend is for desktop screen testing with Espressif's
        ESP32-C3 RISC-V QEMU target and idf.py qemu --graphics.

config PRG32_DISPLAY_ILI9341
    bool "ILI9341 SPI TFT"
    help
        Use the reference ILI9341 320x240 SPI TFT display connected to the
        ESP32-C6 pins configured in main/prg32_config.h.

config PRG32_DISPLAY_QEMU_RGB
    bool "QEMU virtual RGB panel"
    depends on IDF_TARGET_ESP32C3
    help
        Use Espressif QEMU's virtual RGB framebuffer. Run with:
        idf.py qemu --graphics monitor

endchoice

config PRG32_QEMU_FAIL_ON_REAL_HW
    bool "Fail fast when QEMU backend is run on real hardware"
    depends on PRG32_DISPLAY_QEMU_RGB
    default y
    help
        The QEMU RGB backend is not available on physical ESP32 boards.
        Keep this enabled so accidental real-hardware flashes stop clearly
        during display initialization instead of silently losing graphics.

config PRG32_QEMU_UART_INPUT
    bool "Enable QEMU keyboard input through the UART console"
    depends on PRG32_DISPLAY_QEMU_RGB && ESP_CONSOLE_UART
    default y
    help
        Read simple keyboard controls from the QEMU UART console and translate
        them into the normal PRG32 player 1 input bits. This is for desktop
        classroom testing only; physical ESP32-C6 builds still use GPIO buttons.

config PRG32_SPLASH_ENABLED
    bool "Show PRG32 startup splash"
    default y
    help
        Draw the PRG32 splash screen when the resident firmware starts.

config PRG32_SPLASH_DURATION_MS
    int "Startup splash duration in milliseconds"
    depends on PRG32_SPLASH_ENABLED
    default 900
    range 0 5000
    help
        How long the firmware startup splash remains visible before runtime
        initialization continues.

config PRG32_SPLASH_SOUND_ENABLED
    bool "Play welcome sound during startup splash"
    depends on PRG32_SPLASH_ENABLED
    default y
    help
        When the PRG32 I2S audio subsystem is enabled, initialize it and play a
        short welcome tone sequence while the firmware splash is visible.

menu "Performance metrics"

config PRG32_METRICS_ENABLE
    bool "Enable buffered performance metrics upload"
    default n
    help
        Collect frame timing, heap, and input samples in a small ring buffer and
        upload batches to the PRG32 metrics server. Leave this disabled for
        normal classroom gameplay unless a lab explicitly measures performance.

config PRG32_METRICS_SERVER_URL
    string "Metrics server URL"
    depends on PRG32_METRICS_ENABLE
    default "http://192.168.4.2:8080"
    help
        Base URL for the standalone PRG32 MetricsServer Flask app.

config PRG32_METRICS_BOARD_ID
    string "Metrics board identifier"
    depends on PRG32_METRICS_ENABLE
    default "prg32-board"
    help
        Human-readable board identifier stored with each metrics run.

config PRG32_METRICS_SAMPLE_PERIOD_FRAMES
    int "Metrics sample period in frames"
    depends on PRG32_METRICS_ENABLE
    default 1
    range 1 3600
    help
        Record one sample every N frames. Use higher values when measuring long
        runs on slow or unreliable networks.

config PRG32_METRICS_UPLOAD_PERIOD_MS
    int "Metrics upload period in milliseconds"
    depends on PRG32_METRICS_ENABLE
    default 5000
    range 250 60000
    help
        Background upload task period. Recording never waits for this upload.

config PRG32_METRICS_QUEUE_LEN
    int "Metrics upload queue length"
    depends on PRG32_METRICS_ENABLE
    default 512
    range 8 4096
    help
        Number of samples kept in RAM before upload. If the queue fills, PRG32
        drops new samples and reports the drop count with the next batch.

endmenu

endmenu
