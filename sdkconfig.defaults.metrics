# Optional profiling/lab profile. Use together with sdkconfig.defaults:
# idf.py -D SDKCONFIG_DEFAULTS="sdkconfig.defaults;sdkconfig.defaults.metrics" build
CONFIG_PRG32_METRICS_ENABLE=y
CONFIG_PRG32_METRICS_SERVER_URL="http://192.168.4.2:8080"
CONFIG_PRG32_METRICS_BOARD_ID="prg32-board"
CONFIG_PRG32_METRICS_SAMPLE_PERIOD_FRAMES=1
CONFIG_PRG32_METRICS_UPLOAD_PERIOD_MS=5000
CONFIG_PRG32_METRICS_QUEUE_LEN=512
